      { "name": "admin", "description": "Manages organization, sources, users, and settings" },
      { "name": "reviewer", "description": "Approves, rejects, and deprecates capability assets" },
      { "name": "contributor", "description": "Creates and submits capability assets" },
      { "name": "viewer", "description": "Searches and uses approved assets" }
    ]
  },
  "users": [
    {
      "username": "linh",
      "email": "linh@example.com",
      "firstName": "Linh",
      "lastName": "Nguyen",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "orgmemory", "temporary": false }],
      "realmRoles": ["contributor", "viewer"]
    },
    {
      "username": "minh",
      "email": "minh@example.com",
      "firstName": "Minh",
      "lastName": "Tran",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "orgmemory", "temporary": false }],
